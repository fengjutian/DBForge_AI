{
  "name": "dbforge-ai",
  "version": "1.2.2",
  "description": "DBForge AI - Cross-platform desktop database management tool",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icons": "node scripts/generate-icons.js",
    "prebuild": "node scripts/generate-icons.js",
    "prepackage": "node scripts/generate-icons.js",
    "prepackage:win": "node scripts/generate-icons.js",
    "prepackage:mac": "node scripts/generate-icons.js",
    "prepackage:linux": "node scripts/generate-icons.js",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:linux": "electron-vite build && electron-builder --linux",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:main": "tsc --project tsconfig.main.json --noEmit",
    "typecheck:renderer": "tsc --project tsconfig.renderer.json --noEmit"
  },
  "keywords": [
    "electron",
    "database",
    "mysql",
    "ai",
    "sql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@types/three": "^0.184.1",
    "better-sqlite3": "^9.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.8",
    "exceljs": "^4.4.0",
    "hot-formula-parser": "^4.0.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "langchain": "^0.1.37",
    "lucide-react": "^1.18.0",
    "markdown-table-repair": "^1.0.0",
    "monaco-editor": "^0.47.0",
    "mysql2": "^3.9.4",
    "pg": "^8.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sql-formatter": "^15.3.2",
    "ssh2": "^1.15.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "zustand": "^4.5.2",
    "@dbforge/shared": "workspace:*"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/typography": "^0.5.12",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/ssh2": "^1.11.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "fast-check": "^3.18.0",
    "postcss": "^8.4.38",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.3",
    "to-ico": "^1.1.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vitest": "^1.5.0"
  }
}
